  m_Script: {fileID: 11500000, guid: 42479338bc418114483ba7e647ff56c1, type: 3}
  m_Name: PurioDialogue
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSheet
  npcName: Purio
  dialogueLines:
  - Ach, there goes Sifgard Stalker!
  - We need that mare for the race.
  - Darn kids and their fireworks.
  - Can't have a hippodrome race without the hometown hero.
  - If you and I keep this under wraps, maybe my boss won't have my hide.
  - Would you go and fetch that horse for me? I saw him run northward into the woods.
  - 'Superb. Take some backup with ya, too. '
  - Any folks in town will do.
  - There's a reward in it for each of you.
